ition: all 0.3s ease;\n        }\n        .btn-primary:hover {\n            filter: brightness(1.1);\n            transform: translateY(-1px);\n            box-shadow: 0 6px 20px rgba(245, 158, 11, 0.35);\n        }\n\n        .btn-outline {\n            border: 1px solid rgba(255, 255, 255, 0.15);\n            color: #e5e7eb;\n            padding: 8px 20px;\n            border-radius: 9999px; /* Pill shape */\n            background: transparent;\n            transition: all 0.3s ease;\n        }\n        .btn-outline:hover {\n            background: rgba(255, 255, 255, 0.05);\n            border-color: rgba(255, 255, 255, 0.3);\n        }\n\n        /* Status Badge */\n        .status-badge {\n            background: rgba(16, 185, 129, 0.1);\n            color: #10b981;\n            border: 1px solid rgba(16, 185, 129, 0.2);\n            backdrop-filter: blur(4px);\n        }\n\n        /* Footer specific */\n        footer a:hover {\n            color: #f59e0b;\n            transition: color 0.2s;\n        }\n    </style>\n</head>\n<body class=\"antialiased min-h-screen flex flex-col\">\n\n    <!-- TOP BAR (Colorlib/Tooling) -->\n    <div class=\"bg-[#111] border-b border-white/5 py-3 px-6 flex items-center justify-between text-xs md:text-sm\">\n        <div class=\"flex items-center gap-4\">\n            <span class=\"font-bold text-lg tracking-tight\">colorlib<span class=\"text-gray-500\">.</span></span>\n            <div class=\"hidden md:flex items-center gap-2 bg-[#222] px-3 py-1 rounded text-gray-300 cursor-pointer hover:bg-[#2a2a2a]\">\n                <i class=\"fa-solid fa-plus text-[10px]\"></i>\n                <span>FINANCEFLOW</span>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-4 text-gray-400\">\n            <i class=\"fa-solid fa-desktop hover:text-white cursor-pointer\"></i>\n            <i class=\"fa-solid fa-tablet-screen-button hover:text-white cursor-pointer hidden sm:block\"></i>\n            <i class=\"fa-s